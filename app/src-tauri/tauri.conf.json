{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wardrobe",
  "version": "0.1.0",
  "identifier": "com.wardrobe.journal",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Wardrobe",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A quiet desktop app for the contemplative life.",
    "longDescription": "Wardrobe — Scripture journaling, a life timeline, reading records, verse keeping, and time-blocking. All data lives on this computer; no account needed.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
