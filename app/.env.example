# Wardrobe — environment template. Copy to .env.local and fill in.

# Supabase (client-side; safe to expose. RLS protects rows.)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# ESV API (server-side ONLY — never expose to client.
# Used by /api/scripture proxy, never touched by browser code.)
ESV_API_TOKEN=
